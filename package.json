{
  "name": "e-bike-wars",
  "version": "0.1.0",
  "description": "Multiplayer browser game - join via link, no account required",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc && vite build",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "phaser": "^3.80.1",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
